# ==============================================================
# Photon – Root Environment Overrides (OPTIONAL)
# ==============================================================
# All values below have defaults baked into docker-compose.yml.
# This file is only needed if you want to override them.
# Copy to .env and edit as needed.
# ==============================================================

COMPOSE_PROJECT_NAME=photon

# ─── Forwarded Ports ──────────────────────────────────────────
# FORWARD_APP_PORT=8000
# FORWARD_CLIENT_PORT=3000
# FORWARD_SSE_PORT=8080
# FORWARD_MAILPIT_PORT=8025
# FORWARD_MINIO_PORT=9000
# FORWARD_MINIO_CONSOLE_PORT=9001

# ─── Database ────────────────────────────────────────────────
# DB_ROOT_PASSWORD=root
# DB_DATABASE=photon
# DB_USERNAME=photon
# DB_PASSWORD=12345678

# ─── Redis ───────────────────────────────────────────────────
# REDIS_PASSWORD=12345678
# REDIS_PREFIX=photon

# ─── MinIO (S3) ──────────────────────────────────────────────
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=minio12345
# MINIO_BUCKET=vinmo-dev

# ─── SSE ─────────────────────────────────────────────────────
# SSE_ALLOWED_ORIGINS=http://localhost:3000