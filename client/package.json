{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "": "// TODO: Turbopack desabilitado temporariamente por incompatibilidade com o patch do antd para React 19",
    "dev": "next dev",
    "build": "next build",
    "dev:turbo": "next dev --turbopack",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "start-all": "concurrently -n server,client,worker1,worker2,worker3 -c yellow,cyan,green,magenta,blue \"cd ../server && php artisan serve\" \"npm run dev\" \"cd ../server && php artisan queue:listen\" \"cd ../server && php artisan queue:listen\" \"cd ../server && php artisan queue:listen\"",
    "update:types": "cd ../server && php artisan l5-swagger:generate && cd ../client && npx openapi-typescript ../server/storage/api-docs/api-docs.json -o src/types/api.d.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@tanstack/react-query": "^5.90.20",
    "accept-language": "^3.0.20",
    "antd": "^6.2.3",
    "axios": "^1.13.4",
    "dayjs": "^1.11.19",
    "filesize": "^11.0.13",
    "framer-motion": "^12.33.0",
    "i18next": "^25.8.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-resources-to-backend": "^1.2.1",
    "libphonenumber-js": "^1.12.36",
    "motion": "^12.33.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^14.4.0",
    "react-i18next": "^15.7.4",
    "react-use": "^17.6.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.19.32",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
